{
  "name": "sidebery",
  "version": "5.5.2",
  "description": "Manage your tabs and bookmarks in sidebar",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "node build/all.js --dev",
    "dev.chrome": "node build/all.js --dev --chromium",
    "build.chrome": "node build/all.js --chromium",
    "pack.chrome": "npm run build.chrome && mkdir -p dist && rm -f dist/treebery-chrome.zip && cd addon && zip -r -q -X ../dist/treebery-chrome.zip . && cd ..",
    "dev.styles": "node build/styles.js --dev",
    "dev.html": "node build/html.js --dev",
    "dev.copy": "node build/copy.js --dev",
    "dev.scripts": "node build/scripts.js --dev",
    "dev.run": "node build/webext.run.js --dev",
    "build.styles": "node build/styles.js",
    "build.html": "node build/html.js",
    "build.copy": "node build/copy.js",
    "build.scripts": "node build/scripts.js",
    "build.ext": "web-ext build --source-dir ./addon -a dist/ -i __tests__",
    "build.run": "node build/webext.run.js",
    "build": "node build/all.js",
    "vite": "node build/all.vite.js",
    "clear.npm": "rm -rf node_modules package-lock.json",
    "clear": "rm -rf addon",
    "lint.eslint": "eslint ./src",
    "lint.types": "vue-tsc --noemit",
    "lint": "npm run lint.eslint && npm run lint.types",
    "changelog": "node build/changelog.js",
    "addon": "node build/addon.js",
    "release-notes": "node build/release-notes.js",
    "release.nightly": "node build/release-nightly.js",
    "test": "vitest run",
    "test.watch": "vitest watch"
  },
  "author": "mbnuqw",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/compiler-sfc": "3.5.38",
    "@vue/language-plugin-pug": "3.3.5",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "pug": "3.0.4",
    "stylus": "0.64.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5",
    "web-ext": "10.4.0"
  },
  "dependencies": {
    "vue": "3.5.38"
  },
  "prettier": {
    "arrowParens": "avoid",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 100,
    "useTabs": false
  },
  "alias": {
    "src": "./src"
  },
  "browserslist": [
    "Firefox >= 140"
  ],
  "sideEffects": [
    "./src/services/_compat.chrome.ts"
  ]
}
